{
  "name": "relaygate-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "RelayGate Desktop — native cross-platform GUI for the RelayGate dashboard",
  "homepage": "https://relaygate.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/RelayOne/relaygate-desktop.git"
  },
  "author": {
    "name": "RelayGate",
    "email": "support@relaygate.ai",
    "url": "https://relaygate.ai"
  },
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "electron .",
    "dev": "tsc -w -p tsconfig.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac --config electron-builder.mac.yml",
    "dist:win": "npm run build && electron-builder --win",
    "test:smoke": "npm run build && tsx tests/smoke.test.ts",
    "test:gateway": "tsx tests/gateway.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "puppeteer-core": "^23.10.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
