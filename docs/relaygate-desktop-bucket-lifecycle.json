{
  "lifecycle": {
    "rule": [
      {
        "action": { "type": "Delete" },
        "condition": {
          "age": 30,
          "matchesPrefix": [
            "relaygate-desktop/dev/"
          ]
        }
      },
      {
        "action": { "type": "Delete" },
        "condition": {
          "age": 90,
          "matchesPrefix": [
            "relaygate-desktop/staging/"
          ]
        }
      }
    ]
  }
}
